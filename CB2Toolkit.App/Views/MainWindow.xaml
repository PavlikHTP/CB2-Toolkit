<Window x:Class="CB2Toolkit.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:CB2Toolkit.Core;assembly=CB2Toolkit.Core" 
        Title="{x:Static core:AppMetadata.Title}" 
        Height="650" Width="950"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#121214">
    
    <Window.Resources>
        <Style x:Key="PhoneCallButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="Width" Value="45"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="13,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E1E24"/>
                    <Setter Property="Foreground" Value="#4D7CFE"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" 
                      ResizeBorderThickness="5" 
                      GlassFrameThickness="0" 
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>
    
    <Grid>
        <Border BorderBrush="#2D2D35" BorderThickness="1">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                            <Setter Property="Margin" Value="8"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Border Grid.Row="0" Background="#16161A" BorderBrush="#1E1E22" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0,0,0">
                            <TextBlock Text="{x:Static core:AppMetadata.Title}" Foreground="#9CA3AF" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Static core:AppMetadata.VersionString}" Foreground="#6B7280" FontSize="10" VerticalAlignment="Bottom" Margin="6,0,0,1"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" WindowChrome.IsHitTestVisibleInChrome="True">
                            <Button Style="{StaticResource PhoneCallButtonStyle}" Click="VoiceCall_Click" ToolTip="P2P Voice Call">
                                <Path Data="M6.62,10.79C8.06,13.62 10.38,15.94 13.21,17.38L15.41,15.18C15.69,14.9 16.08,14.82 16.43,14.93C17.55,15.3 18.75,15.5 20,15.5A1,1 0 0,1 21,16.5V20A1,1 0 0,1 20,21A17,17 0 0,1 3,4A1,1 0 0,1 4,3H7.5A1,1 0 0,1 8.5,4C8.5,5.25 8.7,6.45 9.07,7.57C9.18,7.92 9.1,8.31 8.82,8.59L6.62,10.79Z" 
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" 
                                      Stretch="Uniform" Width="14" Height="14" SnapsToDevicePixels="True"/>
                            </Button>
                            <Button Content="—" Style="{StaticResource WindowControlButtonStyle}" Click="Minimize_Click"/>
                            <Button Content="▢" Style="{StaticResource WindowControlButtonStyle}" Click="Maximize_Click"/>
                            <Button Content="✕" x:Name="CloseBtn" Click="Close_Click">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource WindowControlButtonStyle}">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#EF4444"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border x:Name="UpdateBanner" Grid.Row="1" Background="#1E1B4B" BorderBrush="#312E81" BorderThickness="0,0,0,1" Visibility="Collapsed" Padding="15,8">
                    <Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock x:Name="UpdateText" Foreground="#E0E7FF" FontSize="13" VerticalAlignment="Center" FontWeight="Medium"/>
                            <Button Content="Download" Margin="15,0,0,0" Padding="12,4" Background="#4F46E5" Foreground="White" FontWeight="SemiBold" FontSize="12" Click="DownloadUpdate_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#4338CA"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                        <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" Foreground="#A5B4FC" FontSize="14" BorderThickness="0" Cursor="Hand" Click="CloseBanner_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <ContentControl x:Name="MainContentHolder" Grid.Row="2"/>
            </Grid>
        </Border>
    </Grid>
</Window>