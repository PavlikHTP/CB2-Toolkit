<Window x:Class="CB2Toolkit.Views.VoiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Height="540" Width="530"
        Background="Transparent">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="0" GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="StatusConnectedBrush" Color="#10B981"/>
        <SolidColorBrush x:Key="StatusDisconnectedBrush" Color="#6B7280"/>
        <SolidColorBrush x:Key="TextConnectedBrush" Color="#10B981"/>
        <SolidColorBrush x:Key="TextDisconnectedBrush" Color="#9CA3AF"/>
        
        <Style TargetType="Slider">
            <Setter Property="Background" Value="#2B2B30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border x:Name="TrackBackground" Background="#2B2B30" Height="4" CornerRadius="2" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb Width="12" Height="12" Focusable="False">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#4D7CFE" CornerRadius="6"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#1E1E22"/>
            <Setter Property="Foreground" Value="#F3F4F6"/>
            <Setter Property="BorderBrush" Value="#2B2B30"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="MainGrid" SnapsToDevicePixels="True">
                            <ToggleButton x:Name="PART_ToggleButton" 
                                          BorderBrush="{TemplateBinding BorderBrush}" 
                                          BorderThickness="{TemplateBinding BorderThickness}" 
                                          Background="{TemplateBinding Background}" 
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Chrome" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5">
                                            <Grid HorizontalAlignment="Right" Width="30">
                                                <Path x:Name="Arrow" Fill="#9CA3AF" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M0,0 L4,4 L8,0 Z"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Chrome" Property="Background" Value="#252529" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="10,3,30,3" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <Popup x:Name="PART_Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#1E1E22" BorderThickness="1" BorderBrush="#2B2B30" CornerRadius="5"/>
                                    <ScrollViewer Margin="4" SnapsToDevicePixels="True">
                                        <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#4B5563"/>
                                <Setter Property="Background" Value="#16161A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Foreground" Value="#F3F4F6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Border" Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#4D7CFE"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#3B66E0"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#121214" BorderBrush="#2D2D35" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#16161A" CornerRadius="7,7,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="P2P VOICE CALL" Foreground="#9CA3AF" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Margin="15,0,0,0"/>
                    <Button Content="✕" HorizontalAlignment="Right" Width="45" Height="32" Background="Transparent" Foreground="#9CA3AF" BorderThickness="0" Cursor="Hand" WindowChrome.IsHitTestVisibleInChrome="True" Click="Close_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#EF4444"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="Friend IP Address" Foreground="#9CA3AF" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBox x:Name="FriendIpTextBox" Text="26.x.x.x" Background="#1E1E22" Foreground="#F3F4F6" BorderBrush="#2B2B30" BorderThickness="1" Padding="10,8" FontSize="13">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,0,0,16">
                    <TextBlock Text="Target UDP Port" Foreground="#9CA3AF" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBox x:Name="PortTextBox" Text="55555" Background="#1E1E22" Foreground="#F3F4F6" BorderBrush="#2B2B30" BorderThickness="1" Padding="10,8" FontSize="13">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                </StackPanel>

                <Grid Grid.Row="2" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Input Device" Foreground="#9CA3AF" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ComboBox x:Name="InputDeviceComboBox" Height="38"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Output Device" Foreground="#9CA3AF" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ComboBox x:Name="OutputDeviceComboBox" Height="38"/>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="3" Margin="0,0,0,20">
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="Microphone Volume" Foreground="#9CA3AF" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="MicVolumeValueText" Text="x1.0" Foreground="#4D7CFE" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>
                    <Slider x:Name="MicVolumeSlider" Minimum="0" Maximum="3" Value="1" SmallChange="0.1" LargeChange="0.5" ValueChanged="MicVolumeSlider_ValueChanged"/>
                </StackPanel>

                <Grid Grid.Row="4" VerticalAlignment="Top" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#16161A" CornerRadius="5" Padding="15,10" Margin="0,0,10,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#6B7280" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock x:Name="StatusText" Text="Disconnected" Foreground="#9CA3AF" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel x:Name="NetworkStatsPanel" Grid.Column="1" Orientation="Horizontal" Visibility="Collapsed" VerticalAlignment="Center">
                                <TextBlock x:Name="PingText" Text="0 ms" Foreground="#4D7CFE" FontSize="11" FontWeight="Bold" Margin="0,0,8,0"/>
                                <TextBlock x:Name="LossText" Text="0%" Foreground="#EF4444" FontSize="11" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Border Background="#16161A" CornerRadius="5" Width="115" Padding="10,6" Margin="0,0,8,0">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="MY VOICE" Foreground="#4B5563" FontSize="8" FontWeight="Bold" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                                <Grid Background="#2B2B30" Height="4">
                                    <Border Background="#2B2B30" CornerRadius="2"/>
                                    <Border Background="#4D7CFE" HorizontalAlignment="Left" Width="95" CornerRadius="2" RenderTransformOrigin="0,0.5">
                                        <Border.RenderTransform>
                                            <ScaleTransform x:Name="LocalVolumeScale" ScaleX="0"/>
                                        </Border.RenderTransform>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="#16161A" CornerRadius="5" Width="115" Padding="10,6">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="REMOTE VOICE" Foreground="#4B5563" FontSize="8" FontWeight="Bold" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                                <Grid Background="#2B2B30" Height="4">
                                    <Border Background="#2B2B30" CornerRadius="2"/>
                                    <Border Background="#10B981" HorizontalAlignment="Left" Width="95" CornerRadius="2" RenderTransformOrigin="0,0.5">
                                        <Border.RenderTransform>
                                            <ScaleTransform x:Name="VolumeScale" ScaleX="0"/>
                                        </Border.RenderTransform>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button x:Name="ConnectBtn" Content="Connect" Width="120" Height="38" Background="#4D7CFE" Foreground="White" FontSize="13" FontWeight="SemiBold" Cursor="Hand" Margin="0,0,10,0" Click="Connect_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="5">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="Border" Property="Background" Value="#1E1E22"/>
                                                        <Setter Property="Foreground" Value="#4B5563"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#3B66E0"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button x:Name="DisconnectBtn" Content="Disconnect" Width="120" Height="38" Background="#2B2B30" Foreground="#9CA3AF" FontSize="13" FontWeight="SemiBold" Cursor="Hand" Click="Disconnect_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="5">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="Border" Property="Background" Value="#1E1E22"/>
                                                        <Setter Property="Foreground" Value="#4B5563"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#35353B"/>
                                            <Setter Property="Foreground" Value="#F3F4F6"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <ToggleButton x:Name="MuteMicToggle" Width="38" Height="38" Cursor="Hand" Click="MuteMic_Click" Margin="0,0,8,0">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border x:Name="BtnBorder" Background="#2B2B30" CornerRadius="5">
                                                    <Path x:Name="MicIcon" Data="M12 14c1.66 0 3-1.34 3-3V5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3zm5.3-3c0 3-2.54 5.1-5.3 5.1S6.7 14 6.7 11H5c0 3.42 2.72 6.23 6 6.72V21h2v-3.28c3.28-.48 6-3.3 6-6.72h-1.7z" 
                                                          Fill="#9CA3AF" Stretch="Uniform" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="BtnBorder" Property="Background" Value="#35353B"/>
                                                    </Trigger>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="BtnBorder" Property="Background" Value="#EF4444"/>
                                                        <Setter TargetName="MicIcon" Property="Fill" Value="White"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>

                        <ToggleButton x:Name="DeafenToggle" Width="38" Height="38" Cursor="Hand" Click="Deafen_Click">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border x:Name="BtnBorder" Background="#2B2B30" CornerRadius="5">
                                                    <Path x:Name="DeafenIcon" Data="M12 2c-4.97 0-9 4.03-9 9v7c0 1.66 1.34 3 3 3h3v-8H5v-2c0-3.87 3.13-7 7-7s7 3.13 7 7v2h-4v8h3c1.66 0 3-1.34 3-3v-7c0-4.97-4.03-9-9-9z" 
                                                          Fill="#9CA3AF" Stretch="Uniform" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="BtnBorder" Property="Background" Value="#35353B"/>
                                                    </Trigger>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="BtnBorder" Property="Background" Value="#EF4444"/>
                                                        <Setter TargetName="DeafenIcon" Property="Fill" Value="White"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>