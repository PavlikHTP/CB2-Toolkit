<Window x:Class="CB2Toolkit.CodeEditor.Views.ModernMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Notification" Height="Auto" Width="440" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#4D7CFE"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3B66E0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryBtn" BasedOn="{StaticResource PrimaryBtn}" TargetType="Button">
            <Setter Property="Background" Value="#2B2B30"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#35353B"/>
                    <Setter Property="Foreground" Value="#F3F4F6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E22"/>
            <Setter Property="Foreground" Value="#F3F4F6"/>
            <Setter Property="BorderBrush" Value="#2B2B30"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#4D7CFE"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="WindowBorder" Background="#16161A" BorderBrush="#2B2B30" BorderThickness="1" CornerRadius="8" MouseLeftButtonDown="Border_MouseLeftButtonDown" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.5"/>
        </Border.Effect>
        
        <Grid Margin="24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Path x:Name="StatusIcon" Grid.Column="0"
                      Data="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10,10-4.48,10-10S17.52,2,12,2z" 
                      Fill="#4D7CFE" Width="28" Height="28" Stretch="Uniform" Margin="0,2,16,0" VerticalAlignment="Top"/>
                
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="TitleTextBlock" Text="Title" FontSize="14" FontWeight="Bold" Foreground="#F3F4F6" Margin="0,0,0,4"/>
                    <TextBlock x:Name="MessageTextBlock" Text="Message text goes here..." FontSize="13" Foreground="#9CA3AF" TextWrapping="Wrap" Margin="0,0,0,12"/>
                    
                    <TextBox x:Name="InputTextBox" Style="{StaticResource ModernTextBox}" Visibility="Collapsed" Margin="0,4,0,4"/>
                </StackPanel>
            </Grid>
            
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnYes" Content="Yes" Style="{StaticResource PrimaryBtn}" Width="85" Margin="8,0,0,0" Click="BtnYes_Click" Visibility="Collapsed"/>
                <Button x:Name="BtnNo" Content="No" Style="{StaticResource SecondaryBtn}" Width="85" Margin="8,0,0,0" Click="BtnNo_Click" Visibility="Collapsed"/>
                <Button x:Name="BtnOk" Content="OK" Style="{StaticResource PrimaryBtn}" Width="85" Margin="8,0,0,0" Click="BtnOk_Click" Visibility="Collapsed" IsDefault="True"/>
                <Button x:Name="BtnCancel" Content="Cancel" Style="{StaticResource SecondaryBtn}" Width="85" Margin="8,0,0,0" Click="BtnCancel_Click" Visibility="Collapsed" IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>