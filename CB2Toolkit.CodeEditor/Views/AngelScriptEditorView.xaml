<UserControl x:Class="CB2Toolkit.CodeEditor.Views.AngelScriptEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
             xmlns:models1="clr-namespace:CB2Toolkit.Core.Models.Settings;assembly=CB2Toolkit.Core"
             xmlns:models="clr-namespace:CB2Toolkit.Core.Models;assembly=CB2Toolkit.Core"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="950"
             PreviewKeyDown="View_PreviewKeyDown"
             PreviewMouseDown="View_PreviewMouseDown">


    <UserControl.Resources>
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#232329" />
            <Setter Property="Foreground" Value="#F3F4F6" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2D2D35" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActionToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#F3F4F6" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2D2D35" />
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#3F3F46" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ActionIconButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="#16161A" />
            <Setter Property="BorderBrush" Value="#232329" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="4">
                            <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="#E2E2E9" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Grid SnapsToDevicePixels="True">
                            <Border Name="Bd" Background="Transparent" CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="CheckSymbol" />
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="Header" />
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="Arrow" />
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter ContentSource="Header" Grid.Column="2" HorizontalAlignment="Left"
                                                      VerticalAlignment="Center" />
                                    <Popup Name="Popup" Placement="Right" IsOpen="{TemplateBinding IsSubmenuOpen}"
                                           Focusable="False" AllowsTransparency="True">
                                        <Border Background="#16161A" BorderBrush="#232329" BorderThickness="1"
                                                CornerRadius="6" Padding="4">
                                            <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                        </Border>
                                    </Popup>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#232329" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="#D4D4D4" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Name="Bd" Background="Transparent" BorderThickness="0" Padding="4,6"
                                    SnapsToDevicePixels="true">
                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="New File" Click="ContextMenu_NewFile_Click" />
                                        <MenuItem Header="New Folder" Click="ContextMenu_NewFolder_Click" />
                                        <MenuItem Header="Rename" Click="ContextMenu_Rename_Click" />
                                        <MenuItem Header="Delete" Click="ContextMenu_Delete_Click" />
                                        <MenuItem Header="Duplicate" Click="ContextMenu_Duplicate_Click" />
                                        <MenuItem Header="Make Archive" Click="MakeArchive_Click" />
                                        <Separator Background="#232329" Margin="0,4" />
                                        <MenuItem Header="Copy Path" Click="ContextMenu_CopyPath_Click" />
                                        <MenuItem Header="Copy Relative Path"
                                                  Click="ContextMenu_CopyRelativePath_Click" />
                                        <Separator Background="#232329" Margin="0,4" />
                                        <MenuItem Header="Reveal in Explorer"
                                                  Click="ContextMenu_RevealInExplorer_Click" />
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton x:Name="Expander" ClickMode="Press"
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                  Focusable="False">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent" Width="16" Height="16">
                                                    <Path x:Name="Arrow" Data="M 6,4 L 10,8 L 6,12" Stroke="#6B7280"
                                                          StrokeThickness="1.5" StrokeLineJoin="Round"
                                                          StrokeEndLineCap="Round" StrokeStartLineCap="Round"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Arrow" Property="Data"
                                                                Value="M 4,6 L 8,10 L 12,6" />
                                                        <Setter TargetName="Arrow" Property="Stroke" Value="#9CA3AF" />
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Arrow" Property="Stroke" Value="#F3F4F6" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <ContentPresenter Name="PART_Header" Grid.Column="1" ContentSource="Header"
                                                      HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                            <ItemsPresenter Name="ItemsHost" Grid.Row="1" Margin="14,0,0,0" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden" />
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="false">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="true">
                                <Setter TargetName="Bd" Property="Background" Value="#232329" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" SourceName="Bd" Value="true">
                                <Setter TargetName="Bd" Property="Background" Value="#1C1C22" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#121214" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#3F3F46" CornerRadius="4" Margin="2" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="14" />
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="{TemplateBinding Background}">
                                    <Track Name="PART_Track">
                                        <Track.Thumb>
                                            <Thumb>
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border Background="#3F3F46" CornerRadius="4" Margin="2" />
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="14" />
                    <Setter Property="Height" Value="Auto" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid Background="{TemplateBinding Background}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <ScrollContentPresenter Grid.Column="0" Grid.Row="0" Margin="{TemplateBinding Padding}"
                                                    Content="{TemplateBinding Content}"
                                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                                    CanContentScroll="{TemplateBinding CanContentScroll}" />
                            <ScrollBar Name="PART_VerticalScrollBar" Grid.Column="1" Grid.Row="0"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" />
                            <ScrollBar Name="PART_HorizontalScrollBar" Grid.Column="0" Grid.Row="1"
                                       Orientation="Horizontal" Value="{TemplateBinding HorizontalOffset}"
                                       Maximum="{TemplateBinding ScrollableWidth}"
                                       ViewportSize="{TemplateBinding ViewportWidth}"
                                       Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}" />
                            <Rectangle Grid.Column="1" Grid.Row="1" Fill="#121214" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#121214">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1A1A1E" Padding="16,6" BorderBrush="#232329" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="⬅ Back to Hub" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,12,0"
                            Click="BackToMenu_Click" Cursor="Hand" />

                    <Button Content="📄 File ▾" Style="{StaticResource ToolbarButtonStyle}"
                            Click="FileMenuButton_Click" Cursor="Hand">
                        <Button.ContextMenu>
                            <ContextMenu x:Name="FileMenu">
                                <MenuItem Header="Save File" InputGestureText="Ctrl+S" Click="SaveFile_Click" />
                                <MenuItem Header="Save All" InputGestureText="Ctrl+Shift+S" Click="SaveAll_Click" />
                                <Separator Background="#232329" Margin="0,4" />
                                <MenuItem Header="Open Project Folder" Click="OpenFolder_Click" />
                                <MenuItem x:Name="RecentFoldersMenu" Header="Recent Projects">
                                    <MenuItem Header="No recent projects" IsEnabled="False" />
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <StackPanel.Resources>
                        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
                            <Setter Property="Background" Value="#232329" />
                            <Setter Property="Foreground" Value="#E2E2E9" />
                            <Setter Property="BorderBrush" Value="#3F3F46" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="Padding" Value="8,5" />
                            <Setter Property="FontFamily" Value="Segoe UI" />
                            <Setter Property="FontSize" Value="12" />
                            <Setter Property="CaretBrush" Value="#4D7CFE" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border x:Name="border"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false"
                                                          HorizontalScrollBarVisibility="Hidden"
                                                          VerticalScrollBarVisibility="Hidden" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="true">
                                                <Setter TargetName="border" Property="BorderBrush" Value="#52525B" />
                                            </Trigger>
                                            <Trigger Property="IsFocused" Value="true">
                                                <Setter TargetName="border" Property="BorderBrush" Value="#4D7CFE" />
                                                <Setter Property="Background" Value="#16161A" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </StackPanel.Resources>

                    <TextBlock Text="Compile Path:" Foreground="#6B7280" VerticalAlignment="Center" Margin="0,0,8,0"
                               FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold" />
                    <TextBox x:Name="CompilePathInput" Width="280" VerticalAlignment="Center" Margin="0,0,16,0"
                             Style="{StaticResource ModernTextBoxStyle}" />

                    <TextBlock Text="Output Name:" Foreground="#6B7280" VerticalAlignment="Center" Margin="0,0,8,0"
                               FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold" />
                    <TextBox x:Name="OutputNameInput" Text="output" Width="110" VerticalAlignment="Center"
                             Margin="0,0,16,0" Style="{StaticResource ModernTextBoxStyle}" />
                    <Button Content="Run Compiler"
                            Background="#4D7CFE"
                            Foreground="White"
                            Padding="16,8"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Click="RunCompiler_Click"
                            Cursor="Hand" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="10" />
                <RowDefinition Height="200" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" MinWidth="150" MaxWidth="450" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#16161A" CornerRadius="6,6,0,0" BorderBrush="#232329"
                            BorderThickness="1,1,1,0" Padding="10,6">
                        <DockPanel>
                            <TextBlock Text="EXPLORER" Foreground="#4B5563" FontFamily="Segoe UI" FontSize="11"
                                       FontWeight="Bold" VerticalAlignment="Center" DockPanel.Dock="Left" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="📄+" ToolTip="New File" Style="{StaticResource ActionIconButtonStyle}"
                                        Margin="0,0,4,0" Click="NewFile_Click" />
                                <Button Content="📁+" ToolTip="New Folder"
                                        Style="{StaticResource ActionIconButtonStyle}" Margin="0,0,4,0"
                                        Click="NewFolder_Click" />
                                <Button Content="🔄" ToolTip="Refresh" Style="{StaticResource ActionIconButtonStyle}"
                                        Click="RefreshTree_Click" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="1" Background="#16161A" CornerRadius="0,0,6,6" BorderBrush="#232329"
                            BorderThickness="1">
                        <TreeView Name="FileTree" Background="Transparent" BorderThickness="0" Padding="4"
                                  KeyDown="FileTree_KeyDown" SelectedItemChanged="FileTree_SelectedItemChanged"
                                  AllowDrop="True" PreviewMouseLeftButtonDown="FileTree_PreviewMouseLeftButtonDown"
                                  MouseMove="FileTree_MouseMove" DragOver="FileTree_DragOver" Drop="FileTree_Drop">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.Resources>
                                <HierarchicalDataTemplate DataType="{x:Type models:FileNode}"
                                                          ItemsSource="{Binding Value}">
                                    <StackPanel Orientation="Horizontal" Margin="0,1,0,1">
                                        <Grid x:Name="IconGrid" Width="22" Height="12" Margin="0,0,6,0"
                                              VerticalAlignment="Center">
                                            <Path x:Name="FolderIcon" Width="15" Height="10.5"
                                                  Data="M 1,3 C 1,2 2,1 3,1 L 6,1 L 8,3 L 15,3 C 16,3 17,4 17,5 L 17,14 C 17,15 16,16 15,16 L 3,16 C 2,16 1,15 1,14 Z"
                                                  Fill="#6B7280" Stretch="Fill" Visibility="Collapsed" />

                                            <Border x:Name="AsIcon" Background="#3F6EF2" CornerRadius="2" Width="22"
                                                    Height="10" VerticalAlignment="Center" HorizontalAlignment="Center"
                                                    Visibility="Collapsed">
                                                <TextBlock Text="AS" Foreground="#FFFFFF" FontSize="6.5"
                                                           FontWeight="Black" FontFamily="Segoe UI"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Margin="0,-1,0,0" />
                                            </Border>

                                            <Border x:Name="JsonIcon" Background="#D97706" CornerRadius="2" Width="22"
                                                    Height="10" VerticalAlignment="Center" HorizontalAlignment="Center"
                                                    Visibility="Collapsed">
                                                <TextBlock Text="JSON" Foreground="#FFFFFF" FontSize="6.5"
                                                           FontWeight="Black" FontFamily="Segoe UI"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Margin="0,-1,0,0" />
                                            </Border>

                                            <Border x:Name="TxtIcon" Background="#4B5563" CornerRadius="2" Width="22"
                                                    Height="10" VerticalAlignment="Center" HorizontalAlignment="Center"
                                                    Visibility="Collapsed">
                                                <TextBlock Text="TXT" Foreground="#FFFFFF" FontSize="6.5"
                                                           FontWeight="Black" FontFamily="Segoe UI"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Margin="0,-1,0,0" />
                                            </Border>

                                            <Border x:Name="DefaultFileIcon" Background="#6B7280" CornerRadius="2"
                                                    Width="22" Height="10" VerticalAlignment="Center"
                                                    HorizontalAlignment="Center" Visibility="Collapsed">
                                                <TextBlock Text="FILE" Foreground="#FFFFFF" FontSize="6.5"
                                                           FontWeight="Black" FontFamily="Segoe UI"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Margin="0,-1,0,0" />
                                            </Border>
                                        </Grid>

                                        <TextBlock Text="{Binding Key}" VerticalAlignment="Center" Foreground="#E2E2E9" />

                                        <Ellipse x:Name="TreeUnsavedDot" Width="7" Height="7" Fill="#F3F4F6"
                                                 Margin="8,1,0,0"
                                                 VerticalAlignment="Center" Visibility="Collapsed" />
                                    </StackPanel>

                                    <HierarchicalDataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                            <Setter TargetName="FolderIcon" Property="Visibility" Value="Visible" />
                                            <Setter TargetName="IconGrid" Property="Width" Value="15" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsDirectory}" Value="False">
                                            <Setter TargetName="DefaultFileIcon" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Extension}" Value=".as">
                                            <Setter TargetName="DefaultFileIcon" Property="Visibility"
                                                    Value="Collapsed" />
                                            <Setter TargetName="AsIcon" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Extension}" Value=".json">
                                            <Setter TargetName="DefaultFileIcon" Property="Visibility"
                                                    Value="Collapsed" />
                                            <Setter TargetName="JsonIcon" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Extension}" Value=".txt">
                                            <Setter TargetName="DefaultFileIcon" Property="Visibility"
                                                    Value="Collapsed" />
                                            <Setter TargetName="TxtIcon" Property="Visibility" Value="Visible" />
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding IsUnsaved}" Value="True">
                                            <Setter TargetName="TreeUnsavedDot" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </HierarchicalDataTemplate.Triggers>
                                </HierarchicalDataTemplate>
                            </TreeView.Resources>
                        </TreeView>
                    </Border>
                </Grid>

                <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="Transparent" Cursor="SizeWE" />

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1A1A1E" BorderBrush="#232329" BorderThickness="1,1,1,0"
                            CornerRadius="6,6,0,0" Padding="14,8">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Name="CurrentFileNameText" Text="No file open" Foreground="#E2E2E9"
                                       FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold" Cursor="Hand"
                                       PreviewMouseLeftButtonDown="CurrentFileNameText_PreviewMouseLeftButtonDown">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="#4D7CFE" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Ellipse Name="UnsavedDot" Width="7" Height="7" Fill="#F3F4F6" Margin="8,1,0,0"
                                     Visibility="Collapsed" />
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1">
                        <Border CornerRadius="0,0,6,6" BorderBrush="#232329" BorderThickness="1,0,1,1"
                                ClipToBounds="True">
                            <avalonEdit:TextEditor Name="CodeEditor" Background="#16161A" Foreground="#E2E2E9"
                                                   FontFamily="Consolas" FontSize="14" ShowLineNumbers="True"
                                                   LineNumbersForeground="#4B5563" Padding="12" />
                        </Border>

                        <Border x:Name="SearchPanel" Background="#1A1A1E" BorderBrush="#232329" BorderThickness="1"
                                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,12,0" Padding="8,4"
                                CornerRadius="6" Visibility="Collapsed" Panel.ZIndex="10">
                            <Border.Resources>
                                <Style x:Key="SearchToggleButtonStyle" TargetType="ToggleButton">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Foreground" Value="#E2E2E9" />
                                    <Setter Property="Padding" Value="6,4" />
                                    <Setter Property="FontSize" Value="11" />
                                    <Setter Property="FontFamily" Value="Segoe UI" />
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2D2D35" />
                                            <Setter Property="Foreground" Value="#FFFFFF" />
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter Property="Background" Value="#232329" />
                                            <Setter Property="Foreground" Value="#4D7CFE" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Resources>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="SearchModeTitle" Text="LOCAL" VerticalAlignment="Center"
                                           FontFamily="Segoe UI" FontSize="10" FontWeight="Bold" Foreground="#E2E2E9"
                                           Margin="2,0,8,0" Width="50" TextAlignment="Center" />
                                <TextBox x:Name="SearchTextBox" Width="180" Height="26" Background="#121214"
                                         Foreground="#E2E2E9" BorderBrush="#232329" CaretBrush="White"
                                         VerticalContentAlignment="Center" Padding="6,0" Margin="0,0,6,0"
                                         KeyDown="SearchTextBox_KeyDown" />
                                <ToggleButton x:Name="MatchCaseToggle" Content="Aa"
                                              Style="{StaticResource SearchToggleButtonStyle}" Width="24" Height="26"
                                              Margin="0,0,2,0" />
                                <ToggleButton x:Name="WholeWordToggle" Content="Ab"
                                              Style="{StaticResource SearchToggleButtonStyle}" Width="24" Height="26"
                                              Margin="0,0,2,0" />
                                <ToggleButton x:Name="RegexToggle" Content=".*"
                                              Style="{StaticResource SearchToggleButtonStyle}" Width="24" Height="26"
                                              Margin="0,0,4,0" />
                                <Button Content="▲" Style="{StaticResource ActionIconButtonStyle}" Width="24"
                                        Height="26" Margin="0,0,2,0" Click="PrevMatch_Click" />
                                <Button Content="▼" Style="{StaticResource ActionIconButtonStyle}" Width="24"
                                        Height="26" Margin="0,0,6,0" Click="NextMatch_Click" />
                                <Button Content="✕" Style="{StaticResource ActionIconButtonStyle}" Width="24"
                                        Height="26" Click="CloseSearch_Click" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch" Background="Transparent" Cursor="SizeNS" />

            <Border Grid.Row="2" Background="#0D0D10" CornerRadius="6" BorderBrush="#232329" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#131317" BorderBrush="#232329" BorderThickness="0,0,0,1"
                            CornerRadius="5,5,0,0" Padding="12,0">
                        <DockPanel>
                            <TextBlock Text="CONSOLE OUTPUT" Foreground="#4B5563" FontFamily="Segoe UI" FontSize="11"
                                       FontWeight="Bold" VerticalAlignment="Center" DockPanel.Dock="Left" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button Content="📋 Copy All" Style="{StaticResource ActionIconButtonStyle}"
                                        Click="CopyConsole_Click" Cursor="Hand" Padding="8,4" Margin="0,0,6,0" />

                                <ToggleButton x:Name="AutoscrollToggle" Content="⬇ Autoscroll" IsChecked="True"
                                              Checked="AutoscrollToggle_Checked" Cursor="Hand" Margin="0,0,6,0">
                                    <ToggleButton.Style>
                                        <Style TargetType="ToggleButton">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="Foreground" Value="#9CA3AF" />
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="Padding" Value="8,4" />
                                            <Setter Property="FontSize" Value="11" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center" />
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#232329" />
                                                    <Setter Property="Foreground" Value="#F3F4F6" />
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter Property="Background" Value="#1A1A22" />
                                                    <Setter Property="Foreground" Value="#4D7CFE" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ToggleButton.Style>
                                </ToggleButton>
                                <Button Content="🗑 Clear" Style="{StaticResource ActionIconButtonStyle}"
                                        Click="ClearConsole_Click" Cursor="Hand" Padding="8,4" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <ScrollViewer Name="ConsoleScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl Name="ConsoleOutput" Padding="12"
                                      MouseDoubleClick="ConsoleOutput_MouseDoubleClick">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Text, Mode=OneWay}" Foreground="{Binding Color}"
                                             FontFamily="Consolas"
                                             FontSize="13" TextWrapping="Wrap" Margin="0,0,0,2"
                                             IsReadOnly="True" Background="Transparent" BorderThickness="0"
                                             SelectionBrush="#3D4D7CFE" CaretBrush="Transparent" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Border Grid.Row="2" Background="#111114" BorderBrush="#232329" BorderThickness="0,1,0,0"
                            Padding="8,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text=">" Foreground="#4D7CFE" FontFamily="Consolas"
                                       FontSize="13" FontWeight="Bold" VerticalAlignment="Center" Margin="6,0,8,0" />
                            <TextBox Grid.Column="1" x:Name="TerminalInput" Background="Transparent"
                                     Foreground="#D4D4D4" BorderThickness="0"
                                     FontFamily="Consolas" FontSize="13" VerticalAlignment="Center"
                                     KeyDown="TerminalInput_KeyDown"
                                     CaretBrush="#4D7CFE" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>